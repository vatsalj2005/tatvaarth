          "file": "330-333.txt",
          "gathaNum": "330-333",
          "title": "अब यहाँ कहते हैं कि निश्चय से यह जीव कर्मों का कर्त्ता नहीं है --"
        },
        {
          "file": "334-335.txt",
          "gathaNum": "334-335",
          "title": "ज्ञानावरणादि कर्म-प्रकृतियों का आत्मा के साथ जो बंध है, वह अज्ञान का ही महात्म्य है, ऐसा बताते हैं --"
        },
        {
          "file": "336-337.txt",
          "gathaNum": "336-337",
          "title": "जब तक कर्मोदय से होने वाले रागादि-भाव को नहीं छोडे तब तक अज्ञानी अन्यथा ज्ञानी"
        },
        {
          "file": "338.txt",
          "gathaNum": "338",
          "title": "कर्म-फल को भोगते रहना जीव का स्वभाव नहीं, अज्ञान भाव"
        },
        {
          "file": "339.txt",
          "gathaNum": "339",
          "title": "ज्ञानी नि:श्शंक होता हुआ कर्म-फल जानता हुआ आराधना में तत्पर रहता है"
        },
        {
          "file": "340-341.txt",
          "gathaNum": "340-341",
          "title": "अब यहाँ बताते हैं कि अज्ञानी जीव नियम से कर्मों का वेदक ही होता है --"
        },
        {
          "file": "342-343.txt",
          "gathaNum": "342-343",
          "title": "अब इसी कर्तृत्व व भोक्तृत्व के अभाव का दृष्टांत पूर्वक समर्थन करते हैं --"
        },
        {
          "file": "344-346.txt",
          "gathaNum": "344-346",
          "title": "अब यहाँ बताते हैं कि जो एकान्त से आत्मा को कर्ता मानते हैं उनके भी अज्ञानी लोगों के समान मोक्ष नहीं है ऐसा उपदेश करते हैं --"
        },
        {
          "file": "347-350.txt",
          "gathaNum": "347-350",
          "title": "अब पूर्व-पक्ष के उत्तर में कथन करते हैं कि निश्चय से आत्मा का पुदगलद्रव्य के साथ में कर्त्ता-कर्म सम्बन्ध नहीं है, तब आत्मा कैसे कर्त्ता बनता है ?"
        },
        {
          "file": "351-354.txt",
          "gathaNum": "351-354",
          "title": "जो करता है वही भोगता है -- द्रव्यार्थिक-नय और अन्य ही कर्ता है और अन्य ही भोगता -- पर्यायार्थिक-नय"
        },
        {
          "file": "355-359.txt",
          "gathaNum": "355-359",
          "title": "भाव-कर्म का कर्त्ता जीव ही है"
        },
        {
          "file": "360-372.txt",
          "gathaNum": "360-372",
          "title": "आत्मा सर्वथा अकर्ता नहीं है, कथंचित् कर्त्ता भी है"
        },
        {
          "file": "373-378.txt",
          "gathaNum": "373-378",
          "title": "सम्यग्दृष्टियों को विषयों के प्रति राग क्यों नहीं होता"
        },
        {
          "file": "379.txt",
          "gathaNum": "379",
          "title": "शब्दादि अचेतन होने से रागादिक की उत्पत्ति में नियामक कारण नहीं"
        },
        {
          "file": "380-386.txt",
          "gathaNum": "380-386",
          "title": "व्यवहार से कर्त्ता और कर्म भिन्न, निश्चय से अभिन्न"
        },
        {
          "file": "387-396.txt",
          "gathaNum": "387-396",
          "title": "इस निश्चय-व्यवहार कथन का दृष्टांत"
        },
        {
          "file": "397-400.txt",
          "gathaNum": "397-400",
          "title": "निश्चय-प्रतिक्रमण-प्रत्याख्यान-आलोचना ही अभेद-नय से निश्चय-चारित्र"
        },
        {
          "file": "401-410.txt",
          "gathaNum": "401-410",
          "title": "इन्द्रियों और मन के विषयों में रमणता -- मिथ्याज्ञान"
        },
        {
          "file": "411-413.txt",
          "gathaNum": "411-413",
          "title": "अज्ञान-चेतना बंध का कारण"
        },
        {
          "file": "414-428.txt",
          "gathaNum": "414-428",
          "title": "अब इसी अर्थ की गाथा कहते हैं --"
        },
        {
          "file": "429-431.txt",
          "gathaNum": "429-431",
          "title": "ज्ञान आहारक क्यों नहीं?"
        },
        {
          "file": "432-435.txt",
          "gathaNum": "432-435",
          "title": "द्रव्य-लिंग भी निश्चय से मुक्ति का कारण नहीं"
        },
        {
          "file": "436.txt",
          "gathaNum": "436",
          "title": "आत्म-रमणता की प्रेरणा"
        },
        {
          "file": "437.txt",
          "gathaNum": "437",
          "title": "भाव-लिंग के बिना द्रव्य-लिंग द्वारा समयसार का ग्रहण नहीं"
        },
        {
          "file": "438.txt",
          "gathaNum": "438",
          "title": "परमार्थ से लिंग मोक्षमार्ग नहीं"
        },
        {
          "file": "439.txt",
          "gathaNum": "439",
          "title": "ग्रन्थ समाप्ति और इसके पढ़ने का फल"
        }
      ]
    },
    {
      "name": "परिशिष्ट",
